{
  "env": {
    "MAX_THINKING_TOKENS": "32000"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(cargo *)",
      "Bash(pytest:*)",
      "Bash(python -m *)",
      "Bash(python:*)",
      "Bash(ruff *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(bun *)",
      "Bash(docker-compose *)",
      "Bash(./loop.sh *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(pre-commit *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "ask": [
      "Bash(psql:*)"
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "defaultMode": "plan"
}
