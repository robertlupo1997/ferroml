from __future__ import annotations

import numpy as np
from numpy.typing import NDArray
from typing import Any

class TreeExplainer:
    @staticmethod
    def from_decision_tree_regressor(model: Any) -> TreeExplainer: ...
    @staticmethod
    def from_decision_tree_classifier(model: Any) -> TreeExplainer: ...
    @staticmethod
    def from_random_forest_regressor(model: Any) -> TreeExplainer: ...
    @staticmethod
    def from_random_forest_classifier(model: Any) -> TreeExplainer: ...
    @staticmethod
    def from_gradient_boosting_regressor(model: Any) -> TreeExplainer: ...
    def explain(self, x: NDArray[np.float64]) -> dict[str, Any]: ...
    def explain_batch(self, x: NDArray[np.float64]) -> dict[str, Any]: ...

# Permutation importance
def permutation_importance_rf_reg(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "r2", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_rf_clf(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "accuracy", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_dt_reg(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "r2", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_dt_clf(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "accuracy", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_gb_reg(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "r2", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_gb_clf(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "accuracy", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_linear(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "r2", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_logistic(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "accuracy", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_et_clf(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "accuracy", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...
def permutation_importance_et_reg(model: Any, x: NDArray[np.float64], y: NDArray[np.float64], metric: str = "r2", n_repeats: int = 10, random_state: int | None = None) -> dict[str, Any]: ...

# Partial dependence (1-D)
def partial_dependence_rf_reg(model: Any, x: NDArray[np.float64], feature_idx: int, grid_resolution: int = 50) -> dict[str, Any]: ...
def partial_dependence_rf_clf(model: Any, x: NDArray[np.float64], feature_idx: int, grid_resolution: int = 50) -> dict[str, Any]: ...
def partial_dependence_gb_reg(model: Any, x: NDArray[np.float64], feature_idx: int, grid_resolution: int = 50) -> dict[str, Any]: ...
def partial_dependence_gb_clf(model: Any, x: NDArray[np.float64], feature_idx: int, grid_resolution: int = 50) -> dict[str, Any]: ...
