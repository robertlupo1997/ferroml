# Individual conditional expectation (ICE)
def ice_rf_reg(model: Any, x: NDArray[np.float64], feature_idx: int, n_grid_points: int = 50, center: bool = False, compute_derivative: bool = False) -> dict[str, Any]: ...
def ice_gb_reg(model: Any, x: NDArray[np.float64], feature_idx: int, n_grid_points: int = 50, center: bool = False, compute_derivative: bool = False) -> dict[str, Any]: ...
